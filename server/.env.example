# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/mood-of-the-major

# Client (for CORS + cookie settings).
# Production (Vercel): https://your-app.vercel.app  — no trailing slash
CLIENT_URL=http://localhost:5173

# JWT secrets — required; production refuses placeholder/short values (16+ chars).
# Render blueprint can generate them via generateValue.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin seed (used by `npm run seed:admin`)
# Password must be 8+ chars with upper, lower, digit, and symbol.
ADMIN_STUDENT_ID=99999999
ADMIN_EMAIL=99999999@kmitl.ac.th
ADMIN_PASSWORD=Admin123!
ADMIN_FACULTY=Administration
ADMIN_MAJOR=Administration
ADMIN_YEAR=4

# Optional: KMITL Developer API key. If unset, the server falls back to
# strict format validation for student verification (no external call).
KMITL_API_KEY=
KMITL_API_BASE_URL=https://api.kmitl.ac.th/v1

# Optional: KMITL SSO (OpenID Connect). Create an SSO client at
# https://developer.kmitl.ac.th/console/sso with redirect URI
# http://localhost:4000/api/auth/kmitl/callback (local) or
# https://<api-host>/api/auth/kmitl/callback (Render). If unset, "Sign in
# with KMITL" is disabled and only local login is available.
KMITL_OIDC_ISSUER=https://sso.kmitl.ac.th/realms/kmitl
KMITL_OIDC_CLIENT_ID=
KMITL_OIDC_CLIENT_SECRET=
KMITL_OIDC_REDIRECT_URI=http://localhost:4000/api/auth/kmitl/callback
